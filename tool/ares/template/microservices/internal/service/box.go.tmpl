package service

import (
	"{{.ProjectName}}/packages/{{.ServiceName}}/internal/db"
	"{{.ProjectName}}/packages/{{.ServiceName}}/internal/models"
	"github.com/inkbamboo/ares-service/tools"
	"github.com/spf13/viper"
)

type BoxService interface {
	GetBox(id uint) (box *models.Box, err error)
}

func NewBoxService(v *viper.Viper, dbs *db.MysqlClients, rcs *db.RedisClients) (s BoxService, err error) {
	s = &boxService{
		v:    v,
		dbs:  dbs,
		rcs:  rcs,
		tool: tools.Tools,
	}
	return
}

type boxService struct {
	v    *viper.Viper
	dbs  *db.MysqlClients
	rcs  *db.RedisClients
	tool *tools.Tool
}

func (s *boxService) GetBox(id uint) (box *models.Box, err error) {
	box.ID = id
	if err = s.dbs.MasterClient.Find(box).Error; err != nil {
		return
	}
	return
}
